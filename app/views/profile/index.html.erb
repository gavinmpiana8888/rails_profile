<div class="container py-5">
  <div class="hero-box">
    <div class="row align-items-center g-4">
      <div class="col-md-4 text-center">
        <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center profile-img">
  <span class="text-white fw-bold">GM</span>
</div>
      </div>

      <div class="col-md-8">
        <h1 class="display-4 fw-bold mb-3">Welcome to My Portfolio</h1>
        <p class="lead mb-4">
          Student | Soccer Player | Aspiring Economist
        </p>

        <div class="d-flex flex-wrap gap-3">
          <%= link_to portfolio_path, class: "btn btn-primary btn-custom" do %>
            <%= bootstrap_icon "briefcase-fill", width: 18, height: 18, class: "me-2" %>
            View My Work
          <% end %>

          <%= link_to about_path, class: "btn btn-outline-light btn-custom" do %>
            <%= bootstrap_icon "person-lines-fill", width: 18, height: 18, class: "me-2" %>
            Learn More
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

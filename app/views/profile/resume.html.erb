<div class="container py-5">
  <div class="text-center mb-5">
    <h2 class="section-title">Resume</h2>
    <p class="lead mt-3">A quick summary of my experience and background.</p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card custom-card">
        <div class="card-body p-4">
          <ul class="list-group list-group-flush">
            <li class="list-group-item">
              <%= bootstrap_icon "mortarboard-fill", width: 18, height: 18, class: "me-2 resume-icon" %>
              Economics Student
            </li>
            <li class="list-group-item">
              <%= bootstrap_icon "trophy-fill", width: 18, height: 18, class: "me-2 resume-icon" %>
              Connecticut College Soccer Player
            </li>
            <li class="list-group-item">
              <%= bootstrap_icon "mic-fill", width: 18, height: 18, class: "me-2 resume-icon" %>
              Public Speaking Experience
            </li>
            <li class="list-group-item">
              <%= bootstrap_icon "people-fill", width: 18, height: 18, class: "me-2 resume-icon" %>
              Leadership and Team Collaboration
            </li>
          </ul>

          <div class="mt-4">
            <%= link_to contact_path, class: "btn btn-primary btn-custom" do %>
              <%= bootstrap_icon "envelope-fill", width: 18, height: 18, class: "me-2" %>
              Contact Me
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

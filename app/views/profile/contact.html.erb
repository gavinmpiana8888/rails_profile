<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="text-center mb-4">
        <h2 class="section-title">Contact Me</h2>
        <p class="lead mt-3">Feel free to reach out with opportunities, questions, or collaborations.</p>
      </div>

      <div class="contact-box">
        <form>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">
                <%= bootstrap_icon "envelope-fill", width: 16, height: 16, class: "me-2" %>
                Email
              </label>
              <input type="email" class="form-control" placeholder="Enter your email">
            </div>

            <div class="col-md-6">
              <label class="form-label">
                <%= bootstrap_icon "person-fill", width: 16, height: 16, class: "me-2" %>
                Name
              </label>
              <input type="text" class="form-control" placeholder="Enter your name">
            </div>

            <div class="col-12">
              <label class="form-label">
                <%= bootstrap_icon "chat-left-text-fill", width: 16, height: 16, class: "me-2" %>
                Message
              </label>
              <textarea class="form-control" rows="5" placeholder="Write your message"></textarea>
            </div>

            <div class="col-12">
              <button type="submit" class="btn btn-primary btn-custom">
                <%= bootstrap_icon "send-fill", width: 18, height: 18, class: "me-2" %>
                Send Message
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!DOCTYPE html>
<html>
  <head>
    <title>Gavin Mpiana Portfolio</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand fw-bold" do %>
          <%= bootstrap_icon "person-circle", width: 22, height: 22, class: "me-2" %>
          Gavin Mpiana
        <% end %>
       <div class="navbar-nav ms-auto d-flex flex-row gap-2"> 
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "About", about_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Portfolio", portfolio_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Resume", resume_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Contact", contact_path, class: "nav-link" %></li>
          </ul>
        </div>
      </div>
    </nav>

    <%= yield %>

    <footer class="footer-style text-center mt-5">
  <div class="container">
    <p class="mb-0">2026 Gavin Mpiana</p>
  </div>
</footer>
  </body>
</html>
